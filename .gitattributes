# Force Unix line endings for all shell scripts and Python files.
# Without this, git on Windows converts LF→CRLF on checkout, which breaks
# bash scripts run on the Pi (carriage returns cause syntax errors).
*.sh        text eol=lf
*.py        text eol=lf
*.json      text eol=lf
*.txt       text eol=lf
*.md        text eol=lf
*.conf      text eol=lf
*.service   text eol=lf
*.rules     text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
